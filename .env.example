# Marvis Bridge — 任务桥接调度器 环境变量
# 复制为 .env 后填入实际值

# ── 运行环境 ──────────────────────────────────
# production → 启用守护进程模式、关闭调试日志
MARVIS_ENV=development

# ── 桥接目录 ──────────────────────────────────
# 共享任务目录（存放 .task / .result / .status 文件）
# MARVIS_BRIDGE_DIR=./shared

# ── 日志 ─────────────────────────────────────
# 日志级别: DEBUG | INFO | WARNING | ERROR
# MARVIS_LOG_LEVEL=INFO
# 日志目录
# MARVIS_LOG_DIR=./logs

# ── 监控参数 ──────────────────────────────────
# Watcher 轮询间隔 (秒)
# MARVIS_POLL_INTERVAL=5
# 任务超时 (秒)
# MARVIS_TASK_TIMEOUT=300
# 最大重试次数
# MARVIS_MAX_RETRIES=3
# 文件锁超时 (秒)
# MARVIS_LOCK_TIMEOUT=10

# ── 飞书通知 ──────────────────────────────────
# 飞书群机器人 Webhook (任务完成/异常通知)
# FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxx

# ── WorkBuddy 集成 ────────────────────────────
# WorkBuddy 项目目录 (用于上下文注入)
# WORKBUDDY_PROJECT_DIR=
